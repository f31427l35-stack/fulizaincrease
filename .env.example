# PayHero API Configuration
# Copy this file to .env for local dev (never commit .env to git)

# PayHero API endpoint (default is correct for most accounts)
PAYHERO_API_URL=https://backend.payhero.co.ke/api/v2/payments

# Your PayHero Channel ID (found in PayHero dashboard)
PAYHERO_CHANNEL_ID=your_channel_id_here

# Authentication - use ONE of the two methods below:

# Method 1: Basic Auth Token (recommended)
# Format: "Basic <base64(username:password)>"
BASIC_AUTH_TOKEN=Basic YOUR_BASE64_TOKEN_HERE

# Method 2: Username & Password (alternative)
PAYHERO_API_USERNAME=your_payhero_username
PAYHERO_API_PASSWORD=your_payhero_password

# The URL PayHero will POST payment results to
# For Vercel: https://your-project.vercel.app/api/mpesa-callback
PAYHERO_CALLBACK_URL=https://your-project.vercel.app/api/mpesa-callback
