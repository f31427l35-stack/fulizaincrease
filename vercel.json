{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/initiate-payment",
      "dest": "/api/initiate-payment.py"
    },
    {
      "src": "/api/payment-status",
      "dest": "/api/payment-status.py"
    },
    {
      "src": "/api/callback",
      "dest": "/api/callback.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
