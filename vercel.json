{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/initiate-payment",
      "dest": "/api/initiate-payment.js"
    },
    {
      "src": "/api/payment-status",
      "dest": "/api/payment-status.js"
    },
    {
      "src": "/api/callback",
      "dest": "/api/paynexus-callback.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
